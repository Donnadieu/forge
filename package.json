{
  "name": "forge",
  "version": "0.1.0",
  "description": "Model-agnostic agent orchestration platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "forge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "tsc --watch",
    "fmt": "biome format --write src/ test/",
    "fmt:check": "biome format src/ test/",
    "lint": "biome lint src/ test/"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "liquidjs": "^10.17.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
